# Unity generated
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Unity Cache (newer versions)
[Uu]nity[Cc]ache/

# Asset meta data should only be ignored when the corresponding asset is ignored
!/[Aa]ssets/**/*.meta

# Autogenerated IDE / build files
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Visual Studio / VS Code / Rider
.vs/
.vsconfig
.vscode/
.idea/
.fleet/
.gradle/

# JetBrains Rider / IntelliJ (extra)
*.iml

# Unity / Visual Studio caches
*.tmp
*.bak
*.swp
*.orig

# Crash reports / packaged builds
sysinfo.txt
*.stackdump

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Optional: ignore Unity Addressables build output (uncomment if used)
# [Aa]ssets/[Aa]ddressableAssetsData/*/*.bin*
# [Aa]ssets/[Aa]ddressableAssetsData/*/*.json*

